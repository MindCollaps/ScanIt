{
  "name": "scanit",
  "version": "0.1.0",
  "description": "Config-driven web scanning application",
  "packageManager": "bun@1.2.22",
  "scripts": {
    "build": "bun run build:server && bun run build:client",
    "build:server": "tsc -p tsconfig.server.json",
    "build:client": "vite build",
    "dev": "docker compose -f docker-compose.dev.yml up --build",
    "dev:inside": "concurrently \"bun run dev:server\" \"bun run dev:client\"",
    "dev:server": "bun --watch src/server/index.ts",
    "dev:client": "bunx --bun vite --host 0.0.0.0 --port 5173",
    "typecheck": "tsc -p tsconfig.server.json --noEmit && vue-tsc -p tsconfig.client.json --noEmit",
    "lint": "eslint . && stylelint 'src/**/*.{vue,css}'",
    "lint:fix": "eslint . --fix && stylelint 'src/**/*.{vue,css}' --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "ci": "bun run typecheck && bun run lint && bun run format:check",
    "start": "bun dist/server/index.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MindCollaps/ScanIt.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "bugs": {
    "url": "https://github.com/MindCollaps/ScanIt/issues"
  },
  "homepage": "https://github.com/MindCollaps/ScanIt#readme",
  "private": true,
  "dependencies": {
    "chokidar": "^5.0.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "vue-router": "^4.6.3",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.3.2",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitejs/plugin-vue": "^6.0.4",
    "concurrently": "^9.2.1",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.8.0",
    "pino-pretty": "^13.1.3",
    "postcss-html": "^1.8.1",
    "prettier": "^3.8.1",
    "stylelint": "^17.4.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-order": "^7.0.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vue": "^3.5.29",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^3.2.5"
  }
}
